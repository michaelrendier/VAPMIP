<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/gold"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Three Prime Directives — three geometry files"
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:paddingBottom="20dp" />

        <!-- Foundations card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Foundations"
                        android:textColor="@color/text_bright"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/foundationsChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WAITING"
                        android:textColor="@color/gold"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Riemann Zeta — what it IS  •  monad_foundations.bin"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:paddingTop="2dp"
                    android:paddingBottom="8dp" />

                <ProgressBar
                    android:id="@+id/foundationsProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="188"
                    android:progress="0"
                    android:progressTint="@color/gold" />

                <TextView
                    android:id="@+id/foundationsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting…"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:paddingTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Meaning card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Meaning"
                        android:textColor="@color/text_bright"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/meaningChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WAITING"
                        android:textColor="@color/blue_light"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tolkien / Salk / Five Works  •  monad_meaning.bin"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:paddingTop="2dp"
                    android:paddingBottom="8dp" />

                <ProgressBar
                    android:id="@+id/meaningProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="80"
                    android:progress="0"
                    android:progressTint="@color/blue_light" />

                <TextView
                    android:id="@+id/meaningStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting…"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:paddingTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fermat card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Fermat / War"
                        android:textColor="@color/text_bright"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/fermatChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WAITING"
                        android:textColor="@color/red_dim"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What it CANNOT BE  •  monad_war.bin"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:paddingTop="2dp"
                    android:paddingBottom="8dp" />

                <ProgressBar
                    android:id="@+id/fermatProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="12"
                    android:progress="0"
                    android:progressTint="@color/red_dim" />

                <TextView
                    android:id="@+id/fermatStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting…"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:paddingTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Done card (hidden until complete) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/doneCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/done_bg"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="COMPLETE"
                    android:textColor="@color/gold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/outputPath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_bright"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
